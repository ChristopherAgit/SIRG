# Ejemplo de variables de entorno para Render
# Rellena los valores y añade como Environment / Secrets en Render.

ASPNETCORE_ENVIRONMENT=Production
ApiBaseUrl=https://<tu-servicio>.onrender.com

# Cadena de conexión (SQL Server) - ejemplo Azure SQL
ConnectionStrings__ConnectionDb=Server=tcp:<tu-servidor>.database.windows.net,1433;Initial Catalog=<tu-db>;Persist Security Info=False;User ID=<usuario>;Password=<contraseña>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;

# Mail settings
MailSettings__EmailFrom=tu@correo.com
MailSettings__SmtpHost=smtp.tu-proveedor.com
MailSettings__SmtpPort=587
MailSettings__SmtpUser=<usuario-smtp>
MailSettings__SmtpPass=<password-smtp>
MailSettings__DisplayName=Constantinopla

# JWT / otros secretos
JwtSettings__SecretKey=<secret>
