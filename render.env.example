# Ejemplo de variables de entorno para Render
# Rellena los valores y añade como Environment / Secrets en Render.

ASPNETCORE_ENVIRONMENT=Production
ApiBaseUrl=https://<tu-servicio>.onrender.com

# Cadena de conexión (PostgreSQL - ejemplo Render)
# Rellena con los valores de tu base de datos en Render y marca como Secret en el Dashboard.
# Ejemplo:
# ConnectionStrings__ConnectionDb=Host=db-host.onrender.com;Port=5432;Database=mi_db;Username=mi_usuario;Password=mi_contraseña;Ssl Mode=Require;Trust Server Certificate=true;
ConnectionStrings__ConnectionDb=Host=<tu-host>;Port=5432;Database=<tu-db>;Username=<usuario>;Password=<contraseña>;Ssl Mode=Require;

# Mail settings
MailSettings__EmailFrom=tu@correo.com
MailSettings__SmtpHost=smtp.tu-proveedor.com
MailSettings__SmtpPort=587
MailSettings__SmtpUser=<usuario-smtp>
MailSettings__SmtpPass=<password-smtp>
MailSettings__DisplayName=Constantinopla

# JWT / otros secretos
JwtSettings__SecretKey=<secret>
