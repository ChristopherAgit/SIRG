@model SIRG.Application.Dtos.EntitiesDto.ReservationsDto

@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="container mt-4">
    <h2 class="mb-3">Editar Reserva</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ReservationID" />

        <div class="card shadow p-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="TableID" class="form-label">Mesa</label>
                <select asp-for="TableID" class="form-control" asp-items="ViewBag.Tables">
                    <option value="">Seleccione una mesa</option>
                </select>
                <span asp-validation-for="TableID" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReservationDate" class="form-label">Fecha de Reserva</label>
                <input asp-for="ReservationDate" type="date" class="form-control" />
                <span asp-validation-for="ReservationDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReservationTime" class="form-label">Hora de Reserva</label>
                <input asp-for="ReservationTime" type="time" class="form-control" />
                <span asp-validation-for="ReservationTime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NumberOfPeople" class="form-label">Cantidad de Personas</label>
                <input asp-for="NumberOfPeople" type="number" min="1" class="form-control" />
                <span asp-validation-for="NumberOfPeople" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}