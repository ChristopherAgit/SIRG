@model SIRG.Application.Dtos.EntitiesDto.ReservationsDto

@{
    ViewData["Title"] = "Cancelar Reserva";
}

<div class="container mt-4">
    <h2 class="text-danger mb-3">Cancelar Reserva</h2>

    <div class="alert alert-warning">
        ¿Seguro que desea cancelar esta reserva?
    </div>

    <div class="card shadow p-4">
        <dl class="row">
            <dt class="col-sm-3">Mesa</dt>
            <dd class="col-sm-9">@Model.TableID</dd>

            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.ReservationDate</dd>

            <dt class="col-sm-3">Hora</dt>
            <dd class="col-sm-9">@Model.ReservationTime</dd>

            <dt class="col-sm-3">Cantidad de Personas</dt>
            <dd class="col-sm-9">@Model.NumberOfPeople</dd>
        </dl>

        <form asp-action="CancelConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.ReservationID" />

            <button type="submit" class="btn btn-danger">Cancelar Reserva</button>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </form>
    </div>
</div>