@model IEnumerable<SIRG.Application.Dtos.EntitiesDto.ReservationsDto>

@{
    ViewData["Title"] = "Reservas";
}

<div class="container mt-4">
    <h2 class="mb-3">Listado de Reservas</h2>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="row">
            <div class="col-md-4">
                <label>Fecha</label>
                <input type="date" name="date" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Hora</label>
                <input type="time" name="time" class="form-control" />
            </div>

            <div class="col-md-4">
                <label>Estado</label>
                <select name="statusId" class="form-control" asp-items="ViewBag.Statuses">
                    <option value="">Todos</option>
                </select>
            </div>

            <div class="col-md-12 mt-3">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </div>
    </form>

    <div class="text-end mb-3">
        <a asp-action="Create" class="btn btn-success">
            <i class="fa fa-plus me-2"></i>Nueva Reserva
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow rounded">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Reservas Registradas</h4>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered align-middle text-center mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Mesa</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Personas</th>
                            <th>Estado</th>
                            <th>Creada</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ReservationID</td>
                                <td>@item.TableID</td>
                                <td>@item.ReservationDate</td>
                                <td>@item.ReservationTime</td>
                                <td>@item.NumberOfPeople</td>
                                <td>@item.StatusID</td>
                                <td>@item.CreatedAt</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.ReservationID"
                                       class="btn btn-sm btn-info me-1">
                                        Ver
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@item.ReservationID"
                                       class="btn btn-sm btn-warning me-1">
                                        Editar
                                    </a>

                                    <a asp-action="Cancel" asp-route-id="@item.ReservationID"
                                       class="btn btn-sm btn-danger">
                                        Cancelar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center">
            No hay reservas registradas.
        </div>
    }
</div>