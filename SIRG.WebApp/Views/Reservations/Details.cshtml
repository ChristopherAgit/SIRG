@model SIRG.Application.Dtos.EntitiesDto.ReservationsDto

@{
    ViewData["Title"] = "Detalle de Reserva";
}

<div class="container mt-4">
    <h2 class="mb-3">Detalle de Reserva</h2>

    <div class="card shadow p-4">
        <dl class="row">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.ReservationID</dd>

            <dt class="col-sm-3">Mesa</dt>
            <dd class="col-sm-9">@Model.TableID</dd>

            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.ReservationDate</dd>

            <dt class="col-sm-3">Hora</dt>
            <dd class="col-sm-9">@Model.ReservationTime</dd>

            <dt class="col-sm-3">Cantidad de Personas</dt>
            <dd class="col-sm-9">@Model.NumberOfPeople</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.StatusID</dd>

            <dt class="col-sm-3">Fecha de Creación</dt>
            <dd class="col-sm-9">@Model.CreatedAt</dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.ReservationID" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </div>
    </div>
</div>