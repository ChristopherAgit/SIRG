@model SIRG.Application.Dtos.EntitiesDto.RestaurantTablesDto

@{
    ViewData["Title"] = "Editar Mesa";
}

<div class="container mt-4">
    <h2>Editar Mesa</h2>

    <form asp-action="Edit">
        <input type="hidden" asp-for="TableID" />

        <div class="card shadow p-4">

            <div class="form-group mb-3">
                <label>Número de Mesa</label>
                <input asp-for="TableNumber" class="form-control" />
                <span asp-validation-for="TableNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label>Capacidad</label>
                <input asp-for="Capacity" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Mesa Activa</label>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">
                    Guardar Cambios
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Volver
                </a>
            </div>

        </div>
    </form>
</div>