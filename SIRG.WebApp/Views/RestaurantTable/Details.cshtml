@model SIRG.Application.Dtos.EntitiesDto.RestaurantTablesDto

@{
    ViewData["Title"] = "Detalles de Mesa";
}

<div class="container mt-4">
    <h2>Detalles de la Mesa</h2>

    <div class="card shadow p-4">

        <dl class="row">

            <dt class="col-sm-3">
                ID
            </dt>
            <dd class="col-sm-9">
                @Model.TableID
            </dd>

            <dt class="col-sm-3">
                Número de Mesa
            </dt>
            <dd class="col-sm-9">
                @Model.TableNumber
            </dd>

            <dt class="col-sm-3">
                Capacidad
            </dt>
            <dd class="col-sm-9">
                @Model.Capacity
            </dd>

            <dt class="col-sm-3">
                Estado
            </dt>
            <dd class="col-sm-9">
                @(Model.IsActive ? "Activa" : "Inactiva")
            </dd>

        </dl>

        <div>
            <a asp-action="Edit" asp-route-id="@Model.TableID" class="btn btn-warning">
                Editar
            </a>

            <a asp-action="Index" class="btn btn-secondary">
                Volver
            </a>
        </div>

    </div>
</div>